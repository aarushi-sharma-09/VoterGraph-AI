# ─────────────────────────────────────────────────────────────────────────────
# VoterGraph.ai — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
POSTGRES_USER=votergraph
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=votergraph_db
# Full DSN used by ms1-core (pg library)
DATABASE_URL=postgresql://votergraph:changeme_local_only@localhost:5432/votergraph_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Neo4j AuraDB (Free Tier) ──────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_aura_password

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=replace_with_your_gemini_studio_key

# ── AWS SES ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
SES_FROM_EMAIL=noreply@yourdomain.com

# ── Service Ports ─────────────────────────────────────────────────────────────
MS1_PORT=3001
MS2_PORT=8000
